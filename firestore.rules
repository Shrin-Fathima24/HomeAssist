rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwnerOrAdmin(docId) {
      return request.auth.uid == docId || isAdmin();
    }

    match /users/{userId} {
      allow create: if isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.uid == userId;

      allow read: if isSignedIn()
          && (
            request.auth.uid == userId
            || isAdmin()
            || (resource.data.role == 'worker' && resource.data.verified == true)
          );

      allow update: if isSignedIn()
          && (
            (request.auth.uid == userId
              && request.resource.data.role == resource.data.role
              && request.resource.data.keys().hasAll(['verified', 'profileComplete', 'documents', 'skills'])
              && request.resource.data.verified == resource.data.verified)
            || (isAdmin()
              && resource.data.role == 'worker'
              && request.resource.data.keys().hasAll(['verified'])
              && resource.data.verified == false
              && request.resource.data.verified == true)
          );

      allow delete: if isAdmin() || request.auth.uid == userId;
    }

    match /chats/{chatId} {
      allow get, list: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;
      allow update, delete: if isSignedIn() && request.auth.uid in resource.data.members;

      match /messages/{messageId} {
        allow read, write: if isSignedIn()
            && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
      }
    }

    match /bookings/{bookingId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn()
          && (
            request.auth.uid == resource.data.userId
            || request.auth.uid == resource.data.workerId
            || isAdmin()
          );
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.workerId is string
          && request.resource.data.rating is number
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5;
      allow read: if isSignedIn();
      allow update, delete: if false;
    }
  }
}